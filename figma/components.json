    "Badge/Transfer": {
      "description": "환승역 label on multi-line stations.",
      "figma": {
        "layout": "Auto Layout · Horizontal · Center",
        "padding": "2 6",
        "cornerRadius": 6
      },
      "spec": {
        "fill": "#f0f0f0",
        "textColor": "#888888",
        "font": "10 / 500"
      }
