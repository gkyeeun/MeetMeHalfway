  "layout": {

    "AppShell": {
      "maxWidth": 480,
      "minHeight": "100vh",
      "background": "#ffffff",
      "margin": "0 auto"
    },

    "ScreenPadding": {
      "top": "clamp(28px, 6vw, 48px)",
      "horizontal": "clamp(16px, 5vw, 28px)",
      "bottom": "96–100px (footer clearance)"
    },

    "FixedFooter": {
      "position": "fixed · bottom 0 · full width",
      "background": "#ffffff",
      "borderTop": "1px solid #f0f0f0",
      "innerPadding": "14px · clamp(16px, 5vw, 28px)",
      "innerMaxWidth": 480
    }
  },

  "motion": {

    "easing": {
      "default": "cubic-bezier(0.25, 0.1, 0.25, 1)",
      "figmaEquivalent": "Custom · P1(0.25,0.10) P2(0.25,1.00)"
    },

    "pageTransition": {
      "enter": "opacity 0→1 · y +10→0 · 220ms",
      "exit":  "opacity 1→0 · y 0→-6 · 160ms"
    },

    "cardEntrance": {
      "initial": "opacity 0 · y +16 · scale 0.98",
      "animate": "opacity 1 · y 0 · scale 1",
      "duration": "350ms",
      "stagger": "70ms per card"
    },

    "tapFeedback": {
      "primaryButton": "scale 0.98",
      "cardHover": "y -2",
      "smallButton": "scale 0.95"
    }
  }
}
