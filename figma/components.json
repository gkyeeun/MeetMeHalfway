      "variants": {
        "Default": {
          "textColor": "#888888",
          "font": "14 / 400",
          "content": "+ 출발지 추가"
        }
      }
    },

    "Card/Origin": {
      "description": "Departure entry card. Changes appearance when fully complete.",
      "figma": {
        "width": "Fill container",
        "layout": "Auto Layout · Vertical · Gap 8",
        "padding": "16 (all sides)",
        "cornerRadius": 14,
        "strokeWidth": 1
      },
      "variants": {
        "Incomplete": {
          "fill": "#FDFCF9",
          "stroke": "#e8e8e8",
          "content": "Header row (number + remove button) · Name input · Station input"
        },
        "Complete": {
          "fill": "#ffffff",
          "stroke": "#111111",
          "content": "Header row · Name input · Station input · ✓ 입력 완료"
        }
      },
      "subcomponents": {
        "Header": {
          "layout": "Auto Layout · Horizontal · Space Between",
          "label": "N번 출발지 — 11 / 700 / #aaaaaa / LS 0.2",
          "removeButton": "− icon — 18px / #bbbbbb"
        },
        "CompletionBadge": {
          "fill": "#22C55E at 12% opacity (circle icon)",
          "textColor": "#22C55E",
          "font": "11 / 500"
        }
      }
    },

    "Card/Candidate": {
      "description": "Middle-point candidate station card in ResultScreen. Top 4px accent bar.",
      "figma": {
        "width": "Fill container",
        "layout": "Auto Layout · Vertical",
        "cornerRadius": 14,
        "strokeWidth": 1.5,
        "overflow": "hidden"
      },
      "variants": {
        "Default": {
          "fill": "#ffffff",
          "stroke": "#ebebeb",
          "shadow": "0 1 4 0 / rgba(0,0,0,0.05)",
          "accentBar": "4px · fill #f0f0f0"
        },
        "TopRank-Unselected": {
          "fill": "{lineColor} at 2.4% opacity",
          "stroke": "{lineColor} at ~38% opacity (hex 60)",
          "accentBar": "4px · fill {lineColor} at ~31% opacity (hex 50)"
        },
        "Selected": {
          "fill": "#ffffff",
          "stroke": "{lineColor} · 1.5px",
          "shadow": "0 4 20 0 / {lineColor} at ~16% opacity (hex 28)",
          "accentBar": "4px · fill {lineColor}"
        }
      },
      "anatomy": {
        "AccentBar": {
          "height": 4,
          "width": "Fill container"
        },
        "Body": {
          "padding": "16 16 18",
          "layout": "Auto Layout · Vertical · Gap 10"
        },
        "RecommendBadge": {
          "shown": "Top rank only",
          "fill": "{lineColor} at 8% opacity",
          "textColor": "{lineColor}",
          "font": "10 / 700 / LS 0.4",
          "padding": "2 7",
          "cornerRadius": 6
        },
        "HeaderRow": {
          "layout": "Auto Layout · Horizontal · Align Center · Gap 8",
          "RankCircle": {
            "size": "22×22",
            "shape": "Circle",
            "fill-default": "#e0e0e0",
            "fill-selected": "{lineColor}",
            "textColor-default": "#888888",
            "textColor-selected": "#ffffff",
            "font": "11 / 700"
          },
          "StationName": {
            "font": "18 / 700 / LS -0.4",
            "color": "#111111"
          },
          "LineBadge": {
            "fill": "{lineColor}",
            "textColor": "#ffffff",
            "font": "11 / 600",
            "padding": "2 7",
            "cornerRadius": 6
          },
          "TransferBadge": {
            "fill": "#f0f0f0",
            "textColor": "#888888",
            "font": "10 / 500",
            "padding": "2 6",
            "cornerRadius": 6
          }
        },
        "DataRow": {
          "layout": "Auto Layout · Horizontal · Space Between",
          "DurationsBlock": {
            "font": "13 / 600 / LS -0.2",
            "color": "#111111"
          },
          "MetaText": {
            "font": "11 / 400",
            "color": "#aaaaaa"
          },
          "ScoreBlock": {
            "label": "10 / 400 / #aaaaaa",
            "number": "18 / 700 / LS -0.5 / #111111",
            "unit": "11 / 400 / #aaaaaa"
          }
        },
        "Description": {
          "font": "11 / 400",
          "lineHeight": 1.6,
          "color-selected": "#888888",
          "color-default": "#cccccc"
        },
        "RouteSection": {
          "shown": "Selected state only",
          "divider": "1px solid #f0f0f0",
          "SectionLabel": {
            "font": "10 / 700 / uppercase / LS 0.8",
            "color": "#aaaaaa"
          },
          "RouteRow": {
            "PersonLabel": "11 / 600 / #666666 · minWidth 36",
            "StationStep": "12 / 400 / #888888 (intermediate) · 12 / 600 / #111111 (final)",
            "Arrow": "10 / #cccccc →",
            "ArrivalBadge": {
              "fill": "{lineColor} at 9% opacity",
              "textColor": "{lineColor}",
              "font": "10 / 600",
              "padding": "1 5",
              "cornerRadius": 6
            },
            "Duration": "11 / 400 / #aaaaaa"
          }
        }
      }
    },

    "Card/Place": {
      "description": "Place result card in PlaceScreen. Uses category accent color.",
      "figma": {
        "width": "Fill container",
        "layout": "Auto Layout · Vertical",
        "padding": "12 14",
        "cornerRadius": 10,
        "strokeWidth": 1.5
      },
      "variants": {
        "Default": {
          "fill": "#ffffff",
          "stroke": "#ebebeb",
          "shadow": "0 1 3 0 / rgba(0,0,0,0.04)"
        },
        "Selected": {
          "fill": "{accentColor} at 2.4% opacity",
          "stroke": "{accentColor}",
          "shadow": "0 2 12 0 / {accentColor} at 9% opacity"
        }
      },
      "anatomy": {
        "TopRow": {
          "layout": "Auto Layout · Horizontal · Align Center · Gap 8",
          "RankCircle": {
            "size": "22×22",
            "shape": "Circle",
            "fill-default": "#d0d0d0",
            "fill-selected": "{accentColor}",
            "textColor": "#ffffff",
            "font": "10 / 700"
          },
          "PlaceName": {
            "font": "14 / 700 / LS -0.2",
            "color": "#111111",
            "truncate": true
          },
          "ActionButtons": {
            "layout": "Auto Layout · Horizontal · Gap 6",
            "items": ["공유", "지도보기", "길찾기"],
