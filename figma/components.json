  "components": {

    "Button/PrimaryCTA": {
      "description": "Full-width main action button. Fixed to bottom of screen via portal.",
      "figma": {
        "width": "Fill container",
        "height": 56,
        "layout": "Auto Layout · Horizontal · Center",
        "cornerRadius": 14,
        "padding": "0"
      },
      "variants": {
        "Default": {
          "fill": "#111111",
          "textColor": "#ffffff",
          "font": "16 / 600",
          "note": "token: component.button-primary.bg"
        },
        "Disabled": {
          "fill": "#e0e0e0",
          "textColor": "#aaaaaa",
          "font": "16 / 600",
          "note": "token: component.button-primary.bg-disabled"
        },
        "Loading": {
          "fill": "#111111",
          "textColor": "#ffffff",
          "font": "16 / 600",
          "content": "Spinner (16×16, border 2px white/35%) + label"
        }
      }
    },

    "Button/ForwardCTA": {
      "description": "Full-width CTA that advances to the next screen. Fixed footer.",
      "figma": {
        "width": "Fill container",
        "layout": "Auto Layout · Horizontal · Center · Gap 6",
        "padding": "15 (all sides)",
        "cornerRadius": 14
      },
      "variants": {
        "Default": {
          "fill": "#111111",
          "textColor": "#ffffff",
          "font": "15 / 600",
          "content": "Label + → arrow (16px)"
        }
      }
    },

    "Button/SecondaryCTA": {
      "description": "Full-width outline button for back/reset actions.",
      "figma": {
        "width": "Fill container",
        "padding": "15 (all sides)",
        "cornerRadius": 14,
        "stroke": "#e0e0e0",
        "strokeWidth": 1
      },
      "variants": {
        "Default": {
          "fill": "#ffffff",
          "textColor": "#333333",
          "font": "15 / 500"
        }
      }
    },

    "Button/Ghost": {
      "description": "Invisible back/navigation button. Appears top-left of screen.",
      "figma": {
        "layout": "Auto Layout · Horizontal · Left · Gap 4",
        "padding": "0",
        "fill": "none"
      },
      "variants": {
        "Default": {
          "textColor": "#888888",
          "font": "14 / 400",
          "content": "← Label"
        }
      }
    },

    "Button/Small": {
      "description": "Inline action buttons inside place cards (공유, 지도보기).",
      "figma": {
        "layout": "Auto Layout · Horizontal · Center",
        "padding": "5 10",
        "cornerRadius": 6,
        "stroke": "#e0e0e0",
        "strokeWidth": 1
      },
      "variants": {
        "Neutral": {
          "fill": "#ffffff",
          "textColor": "#666666",
          "font": "11 / 500"
        },
        "Accent": {
          "fill": "#ffffff",
          "textColor": "{accentColor}",
          "stroke": "{accentColor}50",
          "font": "11 / 600",
          "usage": "길찾기 button"
        }
      }
    },

    "Button/AddOrigin": {
      "description": "Dashed full-width button to add another departure.",
      "figma": {
        "width": "Fill container",
        "layout": "Auto Layout · Horizontal · Center · Gap 6",
        "padding": "12 (all sides)",
        "cornerRadius": 14,
        "stroke": "#d0d0d0",
        "strokeWidth": 1,
        "strokeStyle": "dashed",
        "fill": "none"
