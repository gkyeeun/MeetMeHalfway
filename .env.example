# 카카오 지도 JavaScript 앱 키 (https://developers.kakao.com → 내 애플리케이션 → 앱 키)
VITE_KAKAO_MAP_KEY=your_kakao_javascript_key_here

# 카카오 REST API 키 (같은 앱 → 앱 키 → REST API 키)
# 클라이언트 번들에 포함되지 않음 — Vite dev proxy에서만 사용
KAKAO_REST_KEY=your_kakao_rest_api_key_here

# 공공데이터포털 API 키 (https://www.data.go.kr)
# 서비스명: 국토교통부_도시철도 노선정보
VITE_SUBWAY_API_KEY=your_api_key_here

# 디버그 모드 (true 로 설정하면 콘솔에 API 요청/응답 로그 출력)
VITE_DEBUG=false
