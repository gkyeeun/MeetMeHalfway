        "padding": "10 14",
        "cornerRadius": 14,
        "strokeWidth": 1
      },
      "variants": {
        "Rest": {
          "fill": "#fafafa",
          "stroke": "#e0e0e0",
          "font": "14 / 400 / #111111"
        },
        "Focused": {
          "fill": "#fafafa",
          "stroke": "#000000"
        }
      }
    },

    "Badge/Line": {
      "description": "Subway line identifier badge. Color is the official line color.",
      "figma": {
        "layout": "Auto Layout · Horizontal · Center",
        "padding": "2 7",
        "cornerRadius": 6
      },
      "spec": {
        "fill": "{lineColor}",
        "textColor": "#ffffff",
        "font": "11 / 600"
      }
    },

    "Badge/Category": {
      "description": "Category marker on place cards.",
      "figma": {
        "layout": "Auto Layout · Horizontal · Center",
        "padding": "2 7",
        "cornerRadius": 6
      },
      "spec": {
        "fill": "{categoryColor} at 8% opacity",
        "textColor": "{categoryColor}",
        "font": "10 / 700 / LS 0.4"
      }
